# ============================================================
# pulse — Pi 側環境変数(deploy/.env に配置)
# ============================================================
# cp deploy/env.pi.example deploy/.env して値を記入する。
# 秘密の値(パスワード・API キー・Webhook URL)はここに例示しない。
# 取得した値は .env に直接記入し、チャット等には貼らないこと
# (docs/setup-and-roadmap.md の方針)。
# ============================================================

# --- ホスト固有(必須) ---
# tailscale ip -4 の出力(例: 100.x.y.z)。私的リスナーと PostgreSQL の
# 公開先をこの IP に限定する
TAILNET_IP=

# mp3 アーカイブのホスト側絶対パス(pi.md 1章で作成したもの)
EPISODES_DIR=/home/CHANGEME/catchup-feed/episodes

# 書籍 PDF のホスト側絶対パス(pi.md 1章で作成したもの、D-25)。
# コンテナ内では /data/books に固定マウントされ、books.file_path と
# book_ingest ジョブにはコンテナ内パスが記録される(episodes と同じ流儀)
BOOKS_DIR=/home/CHANGEME/catchup-feed/books

# --- PostgreSQL(必須) ---
# DB 名/ユーザーは catchup-feed が実体として正(progress.md 2026-07-05)。
# Mac 側 env.mac.example の DATABASE_URL と一致させること
POSTGRES_USER=catchup-feed
POSTGRES_DB=catchup-feed
# openssl rand -base64 24 などで生成して記入
POSTGRES_PASSWORD=
# ホスト側公開ポート。旧 catchup-feed の 5432 と衝突しない値
POSTGRES_PORT=5433

# --- ダッシュボード認証(必須、U-3) ---
# openssl rand -base64 48 の出力
JWT_SECRET=
ADMIN_USER=admin
# make admin-hash で生成。.env 内ではハッシュ中の '$' を '$$' にエスケープ
ADMIN_PASSWORD_HASH=

# --- 公開経路 ---
# cloudflared が接続するローカルポート(旧 8080 と衝突しない値)
API_PORT=8090
CORS_ALLOWED_ORIGINS=https://pulse.catchup-feed.com
# 認証 cookie の Domain(D-22)。pulse./radio. で JWT cookie を共有するため親ドメインを指定。
# 空にすると発行ホスト限定になり、ダッシュボード(pulse.)でログインが通らない。
AUTH_COOKIE_DOMAIN=.catchup-feed.com

# --- フィード(§5 / D-6。既定値でよければ空のまま) ---
# FEED_PUBLIC_BASE_URL=https://radio.catchup-feed.com
# FEED_CHANNEL_TITLE=pulse radio
# FEED_CHANNEL_DESCRIPTION=毎朝の技術ニュースラジオ
# FEED_MAX_ITEMS=30
# 私的フィードの enclosure URL ベース(未設定ならリクエスト Host から導出)
# FEED_PRIVATE_BASE_URL=http://<pi の MagicDNS 名>:8081
# 私的リスナーのコンテナ内バインド先(compose の既定 server:8081 のままでよい)
# PRIVATE_FEED_ADDR=server:8081

# --- 要約フォールバック連鎖(U-4 / U-5) ---
GEMINI_API_KEY=
GROQ_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# Mac の Ollama(tailnet 経由)。mac.md 3章の tailscale serve 設定が前提。
# 必ず Mac の Tailscale IP(Mac 上で `tailscale ip -4`)を使う。MagicDNS 名(.ts.net)は
# Ollama の Host ヘッダ検証に 403 で拒否されるため不可(mac.md 3章参照)
OLLAMA_HOST=http://CHANGEME-mac-tailscale-ip:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_ENABLED=true
# SUMMARIZER_CHAR_LIMIT=900
# SUMMARIZER_TIMEOUT=60s

# --- 通知(D-7、U-7 / U-8) ---
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SMTP_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# --- worker(既定値でよければ空のまま) ---
# クロールは毎時(§3.3)
# CRON_SCHEDULE=0 * * * *
# CLEANUP_CRON_SCHEDULE=30 6 * * *
# JOBS_POLL_INTERVAL=10s
# CRAWL_TIMEOUT=30m
# WORKER_TIMEZONE=Asia/Tokyo

# --- 学習ループ(Phase 3、§8.1 / D-18。既定値でよければ空のまま) ---
# server が採点 API(POST /learning/reviews/{id}/grade)のステージ遷移で読む
# 唯一の学習系 env。radio(Mac)の自動解決と同じ遷移ラダーを共有するため、
# **Mac 側 env.mac.example の QUIZ_LADDER_DAYS と必ず同じ値**にすること
# (両ホストで値がずれると採点と自動前進で間隔が食い違う)。
# 他の QUIZ_*(ITEMS_PER_DAY/SLOTS/BACKPRESSURE/AUTO_RESOLVE/WEEKLY_REVIEW_DOW)は
# 出題・生成・自動解決を行う radio 専用で、Pi の server では使われない → Mac 側に置く。
# QUIZ_LADDER_DAYS=1,7,30

# --- レートリミット(Cloudflare Tunnel 経由の公開では必須) ---
# cloudflared は同一ホストの 127.0.0.1 で終端するため、X-Forwarded-For を
# 信頼しないと全リクエストが 127.0.0.1 に見え、公開ルートの per-IP 制限
# (無効トークン連打対策)が効かない。
# クライアント IP の決定は rightmost-untrusted 方式: X-Forwarded-For を
# 右(接続元に近い側)から走査し、RATE_LIMIT_TRUSTED_PROXIES に含まれる
# エントリを剥がして、最初に現れた非信頼 IP を採用する。cloudflared は
# クライアントが送ってきた XFF の末尾に実 IP を「追記」するため、先頭は
# クライアントが自由に詐称できる。この方式なら詐称された先頭は無視され、
# 信頼プロキシが追記した実 IP だけが採用される。
# 【注意】Tunnel を使わず server を直接公開する構成に変えた場合は false
# (または未設定)に戻すこと。その構成では接続元 IP(RemoteAddr)を使う。
RATE_LIMIT_TRUST_PROXY=true
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1/32

# --- 任意 ---
# TZ=Asia/Tokyo
# LOG_LEVEL=info
