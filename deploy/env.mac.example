# ============================================================
# pulse — Mac 側環境変数(~/pulse/.env に配置)
# ============================================================
# cp deploy/env.mac.example ~/pulse/.env して値を記入する。
# deploy/scripts/radio-run.sh と backup-pulse-db.sh がこのファイルを読む。
# 秘密の値はここに例示しない。取得した値は .env に直接記入し、
# チャット等には貼らないこと(docs/setup-and-roadmap.md の方針)。
# ============================================================

# --- Pi への接続(必須) ---
# Pi の PostgreSQL(tailnet 越し、compose.pi.yml の公開ポート 5433)。
# パスワードは Pi 側 deploy/.env の POSTGRES_PASSWORD と同じ値
DATABASE_URL=postgres://catchup-feed:CHANGEME@CHANGEME-pi.tailnet-name.ts.net:5433/catchup-feed?sslmode=disable

# rsync 転送先(§6-5)。パスは Pi の「ホスト側」EPISODES_DIR に合わせる
RADIO_RSYNC_DEST=CHANGEME@CHANGEME-pi.tailnet-name.ts.net:/home/CHANGEME/catchup-feed/episodes

# episodes.audio_path に記録される「Pi コンテナ内」のパス。
# compose.pi.yml が EPISODES_DIR を /data/episodes にマウントしているので固定。
# 【重要】RADIO_RSYNC_DEST(ホスト側パス)と混同しない
RADIO_EPISODES_DIR=/data/episodes

# --- 台本生成 LLM(D-3: 要約と同一の連鎖) ---
GEMINI_API_KEY=
GROQ_API_KEY=
# ローカル Ollama(最終フォールバック)。radio は Mac 上で動くので localhost
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# SUMMARIZER_TIMEOUT=60s

# --- VOICEVOX(U-6 / D-2) ---
# VOICEVOX_URL=http://127.0.0.1:50021
# 仮話者 3 = ずんだもん(ノーマル)。選定は D-2 の手順で
# VOICEVOX_SPEAKER=3
# クレジット表記(U-13)用の話者名の明示指定。未設定なら Engine の /speakers API から
# スタイル ID で自動解決(解決失敗の日はクレジット無し配信を避けて当日スキップ)
# VOICEVOX_SPEAKER_NAME=ずんだもん
# VOICEVOX_SPEED_SCALE=1.0
# VOICEVOX_TIMEOUT=120s
# radio-run.sh がエンジンを自動起動するための展開先(mac.md 4章)。
# 空にすると自動起動せず、起動済みエンジンがなければ当日スキップ(縮退)
VOICEVOX_ENGINE_DIR=/Users/CHANGEME/pulse/voicevox_engine

# --- radio バッチ(既定値でよければ空のまま) ---
# RADIO_SHOW_NAME=pulse
# RADIO_MAX_ARTICLES=8
# RADIO_TIMEZONE=Asia/Tokyo
# RADIO_TIMEOUT=1h
# FFMPEG_PATH=ffmpeg
# LOG_LEVEL=info

# --- 学習ループ / 復習クイズ(Phase 3、§5・§6 / D-17・D-18) ---
# radio が毎朝の私的エピソードに復習クイズを注入するためのパラメータ。
# すべて既定値で動作する(mac.md 13章)。M×ラダー段数 ≦ QUIZ_SLOTS を保つこと
# (§6.2 の飽和算術。既定 M=1 × 3段 = 3 ≦ S=4)。
# QUIZ_LADDER_DAYS だけは Pi の server(採点 API)も読むため、
# **Pi 側 env.pi.example の QUIZ_LADDER_DAYS と必ず同じ値**にすること。
# QUIZ_ITEMS_PER_DAY=1              # M: 1日あたりの学習項目生成数(§5、D-18)
# QUIZ_LADDER_DAYS=1,7,30          # 間隔ラダー(日数、カンマ区切り)。Pi と一致必須
# QUIZ_SLOTS=4                     # S: 1エピソードの出題枠(§6.2)
# QUIZ_BACKPRESSURE_THRESHOLD=30   # 期日超過項目がこの数を超えたら新規生成停止(§5.2)
# QUIZ_AUTO_RESOLVE_AFTER=48h      # 未採点ログの自動前進までの時間(Go duration、D-17)
# QUIZ_WEEKLY_REVIEW_DOW=saturday  # 週次振り返りの曜日(英語名 or 0=日〜6=土、D-21)
# 私的版ショーノートに載る採点ページ URL(§7.5。聴取→採点の唯一の橋)
# RADIO_LEARNING_URL=https://pulse.catchup-feed.com/learning

# --- 書籍レビュー book_review(Phase 3、§7.3 / C-12・D-12。私的・ローカル LLM 限定) ---
# 書籍(私的データ)の紹介台本は Ollama 限定で生成する。要約連鎖の OLLAMA_MODEL
# とは別の env。gemma4:12b は Phase 2 で pull 済み(mac.md 11章)を再利用する。
# BOOK_REVIEW_OLLAMA_MODEL=gemma4:12b   # book_review 台本生成の Ollama モデル(D-12)
# BOOK_REVIEW_CHUNKS=3                  # 1回の book_review で読む book_chunks 数(§7.3)
# PRIVATE_EPISODE_MAX_MINUTES=18        # 私的版の尺ガード。超過時は book_review を翌日へ(§7.1)

# --- transcribe worker(Phase 2、deploy/scripts/transcribe-run.sh)---
# DATABASE_URL は上の radio 用の値を**そのまま共用**する(追加キー不要)。
# 任意キーの一覧と説明は catchup-feed-ai/.env.example が正。使うものだけ
# コメントを外してここに書く(transcribe-run.sh がこのファイルを export し、
# 環境変数がリポジトリ側 .env より常に優先される)。
# catchup-feed-ai の checkout 位置(既定 ~/pulse/catchup-feed-ai。ai.md 2章)
# PULSE_AI_DIR=/Users/CHANGEME/pulse/catchup-feed-ai
# faster-whisper(D-11。初回実行時に自動ダウンロード)
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=auto   # CPU で遅ければ int8
# D-14: 1夜の音源合計上限(秒)。既定 7200 = 2時間
# NIGHTLY_BUDGET_SECONDS=7200
# POLL_INTERVAL_SECONDS=10
# transcribe 終了後、radio(04:30)発火まで Mac を起こしておくブリッジの終端
# TRANSCRIBE_BRIDGE_UNTIL=04:32

# --- バックアップ(deploy/scripts/backup-pulse-db.sh) ---
# Pi への ssh 先(rsync と同じホスト・ユーザーでよい)
PULSE_PI_SSH=CHANGEME@CHANGEME-pi.tailnet-name.ts.net
# Pi ホスト側の episodes ディレクトリ(ミラー元)
PULSE_PI_EPISODES_DIR=/home/CHANGEME/catchup-feed/episodes
# Pi ホスト側の books ディレクトリ(書籍 PDF のミラー元、D-25)
PULSE_PI_BOOKS_DIR=/home/CHANGEME/catchup-feed/books
# PULSE_BACKUP_DIR=/Users/CHANGEME/pulse/backups
# PULSE_BACKUP_RETENTION_DAYS=30
