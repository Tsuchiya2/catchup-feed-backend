# ============================================================
# pulse — Mac 側環境変数(~/pulse/.env に配置)
# ============================================================
# cp deploy/env.mac.example ~/pulse/.env して値を記入する。
# deploy/scripts/radio-run.sh と backup-pulse-db.sh がこのファイルを読む。
# 秘密の値はここに例示しない。取得した値は .env に直接記入し、
# チャット等には貼らないこと(docs/setup-and-roadmap.md の方針)。
# ============================================================

# --- Pi への接続(必須) ---
# Pi の PostgreSQL(tailnet 越し、compose.pi.yml の公開ポート 5433)。
# パスワードは Pi 側 deploy/.env の POSTGRES_PASSWORD と同じ値
DATABASE_URL=postgres://catchup-feed:CHANGEME@CHANGEME-pi.tailnet-name.ts.net:5433/catchup-feed?sslmode=disable

# rsync 転送先(§6-5)。パスは Pi の「ホスト側」EPISODES_DIR に合わせる
RADIO_RSYNC_DEST=CHANGEME@CHANGEME-pi.tailnet-name.ts.net:/home/CHANGEME/catchup-feed/episodes

# episodes.audio_path に記録される「Pi コンテナ内」のパス。
# compose.pi.yml が EPISODES_DIR を /data/episodes にマウントしているので固定。
# 【重要】RADIO_RSYNC_DEST(ホスト側パス)と混同しない
RADIO_EPISODES_DIR=/data/episodes

# --- 台本生成 LLM(D-3: 要約と同一の連鎖) ---
GEMINI_API_KEY=
GROQ_API_KEY=
# ローカル Ollama(最終フォールバック)。radio は Mac 上で動くので localhost
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# SUMMARIZER_TIMEOUT=60s

# --- VOICEVOX(U-6 / D-2) ---
# VOICEVOX_URL=http://127.0.0.1:50021
# 仮話者 3 = ずんだもん(ノーマル)。選定は D-2 の手順で
# VOICEVOX_SPEAKER=3
# クレジット表記(U-13)用の話者名の明示指定。未設定なら Engine の /speakers API から
# スタイル ID で自動解決(解決失敗の日はクレジット無し配信を避けて当日スキップ)
# VOICEVOX_SPEAKER_NAME=ずんだもん
# VOICEVOX_SPEED_SCALE=1.0
# VOICEVOX_TIMEOUT=120s
# radio-run.sh がエンジンを自動起動するための展開先(mac.md 4章)。
# 空にすると自動起動せず、起動済みエンジンがなければ当日スキップ(縮退)
VOICEVOX_ENGINE_DIR=/Users/CHANGEME/pulse/voicevox_engine

# --- radio バッチ(既定値でよければ空のまま) ---
# RADIO_SHOW_NAME=pulse
# RADIO_MAX_ARTICLES=8
# RADIO_TIMEZONE=Asia/Tokyo
# RADIO_TIMEOUT=1h
# FFMPEG_PATH=ffmpeg
# LOG_LEVEL=info

# --- バックアップ(deploy/scripts/backup-pulse-db.sh) ---
# Pi への ssh 先(rsync と同じホスト・ユーザーでよい)
PULSE_PI_SSH=CHANGEME@CHANGEME-pi.tailnet-name.ts.net
# Pi ホスト側の episodes ディレクトリ(ミラー元)
PULSE_PI_EPISODES_DIR=/home/CHANGEME/catchup-feed/episodes
# PULSE_BACKUP_DIR=/Users/CHANGEME/pulse/backups
# PULSE_BACKUP_RETENTION_DAYS=30
